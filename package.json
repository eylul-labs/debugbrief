{
  "name": "debugbrief-vscode",
  "displayName": "DebugBrief",
  "description": "Turn terminal errors, stack traces, and related source files into AI-ready debugging briefs.",
  "version": "0.0.3",
  "publisher": "serdar-ai",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:debugbrief.createFromSelection",
    "onCommand:debugbrief.createFromClipboard"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "debugbrief.createFromSelection",
        "title": "DebugBrief: Create Debug Brief From Selection"
      },
      {
        "command": "debugbrief.createFromClipboard",
        "title": "DebugBrief: Create Debug Brief From Clipboard"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "vsce package --out debugbrief-$npm_package_version.vsix",
    "test": "npm run compile && node --test test/*.test.js",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.8.0"
  }
}
